# Local development environment variables
# Secrets are auto-generated locally if left unset (see app/security.py).
# Set strong values explicitly for production.

# SECRET_KEY=change-me-in-production
# APP_FERNET_KEY=
# APP_HMAC_KEY=

# Database (defaults to local SQLite if unset)
# DATABASE_URL=sqlite:///instance/training_portal.db

# Allow cookies over local HTTP during development
SESSION_COOKIE_SECURE=false

# Upload size limit in MB
MAX_CONTENT_MB=75

# Branding / links
SITE_NAME=Training Simulator Portal
PAYMENT_LINK=
