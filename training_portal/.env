# Flask and app secrets
# Leave blank for local auto-generation in instance/local_secrets.json.
# Set strong explicit values in production.
SECRET_KEY=
APP_FERNET_KEY=
APP_HMAC_KEY=

# Database (default is local SQLite if left blank)
# Example Postgres value:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/training_portal
DATABASE_URL=

# Upload limit in MB
MAX_CONTENT_MB=75

# Cookies and app settings
SESSION_COOKIE_SECURE=true
PAYMENT_LINK=
SITE_NAME=Training Simulator Portal
